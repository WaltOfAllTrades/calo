## Use-Case: getTopItems.js

Pseudocode:

    const WEIGHTS = { days3: 5, days7: 3, days30: 1, presence: 4 };
    const MAX_ITEMS = 25;

    let cache = null;
    let dirty = true;

    export function invalidateTopItems() { dirty = true; }

    export async function getTopItems() {
      if (!dirty && cache) return cache;

      const repo = new CalLogRepository();
      const rows = await repo.getLastNDays(30);

      const now = new Date();
      const cutoff3 = new Date(now.getFullYear(), now.getMonth(), now.getDate() - 3).getTime();
      const cutoff7 = new Date(now.getFullYear(), now.getMonth(), now.getDate() - 7).getTime();

      // Group by normalized name
      const map = new Map();   // key: lowercase name, value: { display, freq3, freq7, freq30, lastSeen }

      for (const row of rows) {
        const raw = (row.name || "").trim();
        if (!raw) continue;
        const key = raw.toLowerCase();
        const ts = new Date(row.createdOn).getTime();

        let entry = map.get(key);
        if (!entry) {
          entry = { display: raw, freq3: 0, freq7: 0, freq30: 0, lastSeen: ts };
          map.set(key, entry);
        }

        entry.freq30 += 1;
        if (ts >= cutoff7) entry.freq7 += 1;
        if (ts >= cutoff3) entry.freq3 += 1;
        if (ts > entry.lastSeen) {
          entry.lastSeen = ts;
          entry.display = raw;          // keep most recent casing
        }
      }

      // Score and sort
      const scored = [...map.values()].map(e => ({
        name: e.display,
        score:
          e.freq3  * WEIGHTS.days3 +
          e.freq7  * WEIGHTS.days7 +
          e.freq30 * WEIGHTS.days30 +
          ((e.freq3 > 0) + (e.freq7 > 0) + (e.freq30 > 0)) * WEIGHTS.presence,
        lastSeen: e.lastSeen
      }));

      scored.sort((a, b) => b.score - a.score);
      const top = scored.slice(0, MAX_ITEMS);

      // Fill remaining slots with most-recent unique names not yet included
      if (top.length < MAX_ITEMS) {
        const included = new Set(top.map(t => t.name.toLowerCase()));
        const recents = [...map.values()]
          .filter(e => !included.has(e.display.toLowerCase()))
          .sort((a, b) => b.lastSeen - a.lastSeen)
          .slice(0, MAX_ITEMS - top.length);
        for (const r of recents) {
          top.push({ name: r.display, score: 0, lastSeen: r.lastSeen });
        }
      }

      cache = top.map(t => t.name);
      dirty = false;
      return cache;
    }

